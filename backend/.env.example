DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LEGACY_SYNC_API_KEY=legacy-dev-key
CERT_SIGNING_SECRET=cert-hmac-dev-secret

# PostgreSQL (Docker: host 5433 -> container 5432)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DB=edupath
POSTGRES_USER=edupath
POSTGRES_PASSWORD=edupath
POSTGRES_CONN_MAX_AGE=60
POSTGRES_CONNECT_TIMEOUT=5
